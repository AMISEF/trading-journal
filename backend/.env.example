# Copy this file to ".env" and fill in real values.

# PostgreSQL connection (async driver). Change the password!
DATABASE_URL=postgresql+asyncpg://tj_user:CHANGE_ME@localhost:5432/trading_journal

# Secret used to sign JWT login tokens. Use a long random string in production.
SECRET_KEY=change-me-to-a-long-random-secret

# How long a login stays valid, in minutes. Default = 7 days.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Which website addresses are allowed to call this API (comma separated).
CORS_ORIGINS=http://localhost:3001,https://trading-journal.cryptosmart.site

# Where uploaded images are stored on disk.
UPLOAD_DIR=./uploads

# --- AI trade analysis (Claude via any compatible gateway, or a Dify app) ---
# Enables the "AI coach". Works with the official Anthropic API, an OpenAI/
# Anthropic-compatible gateway (zyloo.io, OpenRouter), or a self-hosted Dify
# Workflow app. Leave AI_API_KEY empty to keep it disabled.
#
# AI_API_STYLE: "openai"    -> POST <AI_BASE_URL>/chat/completions
#               "anthropic" -> POST <AI_BASE_URL>/v1/messages
#               "dify"      -> POST <AI_BASE_URL>/workflows/run
#
# --- Option A: OpenAI-compatible gateway (e.g. zyloo.io) ---
# AI_API_STYLE=openai
# AI_BASE_URL=https://api.zyloo.io/v1
# AI_API_KEY=
# AI_MODEL=zyloo/claude-opus-4-7

# --- Option B: self-hosted Dify Workflow app (active) ---
# AI_BASE_URL is the Dify **API** base shown in the app's "API Access" panel
# (looks like http://<host>/v1) — NOT the /app console page you browse to.
# The workflow's 4 branches (trade/overall/institutional/chat) already carry
# their own model (e.g. google/gemini-3.1-flash-lite) + system prompt, so
# AI_MODEL below is unused in this mode.
AI_API_STYLE=dify
AI_BASE_URL=http://38.252.8.181/v1
AI_API_KEY=
AI_MODEL=unused-in-dify-mode
AI_MAX_TOKENS=2500
# Longer budget for the 19-section institutional due-diligence report.
AI_REPORT_MAX_TOKENS=8000

# Base URL of the FastAPI backend API.
# Dev (backend running locally):
NEXT_PUBLIC_API_BASE=http://localhost:8001/api

# ── Production, standalone on its own subdomain (trading-journal.cryptosmart.site) ──
# NEXT_PUBLIC_API_BASE=/api

# ── Production, combined under algohub.cryptosmart.site/journal ──
# The app is served under the /journal path prefix (Next.js basePath), and its
# API + uploads are proxied at /journal/api and /journal/uploads by Nginx.
# NEXT_PUBLIC_API_BASE=/journal/api
# NEXT_PUBLIC_BASE_PATH=/journal
#
# IMPORTANT: both vars are inlined at BUILD time — after changing them you MUST
# rebuild the frontend (npm run build) and restart pm2 (tj-frontend).
